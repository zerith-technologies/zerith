# ── Backend ───────────────────────────────────────────────────────────────────

# Porta em que o Spring Boot escuta (Render injeta PORT automaticamente)
PORT=8080

# Render injeta DATABASE_URL no formato postgres://user:pass@host:port/db
# O docker-entrypoint.sh converte para o formato JDBC do Spring Boot
DATABASE_URL=postgres://zerith:zerith@localhost:5432/zerith

# Alternativa: variáveis individuais (usadas quando DATABASE_URL não está presente)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/zerith
SPRING_DATASOURCE_USERNAME=zerith
SPRING_DATASOURCE_PASSWORD=zerith

# MQTT — desabilitar no Render (sem broker disponível no free tier)
MQTT_ENABLED=true
MQTT_BROKER_URL=tcp://localhost:1883
MQTT_CLIENT_ID=zerith-backend

# ── Frontend (build-time, prefixo VITE_ obrigatório) ─────────────────────────

# URL do WebSocket STOMP em produção (wss:// para HTTPS)
# Exemplo: wss://zerith-backend.onrender.com/ws
VITE_WS_URL=ws://localhost:8080/ws
